# HuggingFace API Token (Required for AI Vision Chess Scan)
# Get your free token: https://huggingface.co/settings/tokens
# Steps:
# 1. Create a HuggingFace account (free)
# 2. Go to Settings > Access Tokens
# 3. Create a new token with "read" permissions
# 4. Copy the token and paste it here
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Twilio SMS Configuration (for phone verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
